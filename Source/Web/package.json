{
  "name": "@dolphin/web-harness",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:wasm": "npm run build:wasm:stub",
    "build:wasm:stub": "emcc core/dolphin_web_stub.cpp -O2 --no-entry -s STANDALONE_WASM=1 -Wl,--export=boot_wii_menu -Wl,--export=dolphin_web_boot_target -Wl,--export=dolphin_web_core_version -o public/dolphin-core/dolphin.wasm",
    "build:wasm:real": "cmake --build ${DOLPHIN_WASM_BUILD_DIR:-/tmp/dolphin-wasm-probe} --target dolphin-web-core && node scripts/copy-dolphin-core.mjs",
    "sync:wasm:real": "node scripts/copy-dolphin-core.mjs",
    "predev": "npm run build:wasm",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:wasm && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
